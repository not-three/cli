{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "outDir": "dist",
    "types": [
      "node",
      "mocha"
    ],
    "rootDirs": [
      "src",
      "test"
    ]
  },
  "include": [
    "src/**/*",
    "test/**/*"
  ]
}
